# baan-thong — environment template. Copy to `.env` and fill in real values.
# Never commit `.env`. Real credentials come later; the OTel pipeline runs
# against the stubbed config now.

# --- Runtime ---
NODE_ENV=development
# Origin of the frontend; used to scope CORS + cookie attributes.
WEB_ORIGIN=http://localhost:5173
# Prod domain — baanthong.co. Used for cookie domain + OpenAPI server URLs.
COOKIE_DOMAIN=localhost

# --- Postgres 18 ---
# Matches docker-compose.yml. One DB per service in the modular monolith phase.
DATABASE_URL=postgres://baanthong:baanthong@localhost:5432/baanthong

# --- Auth (JWT) ---
# Long, random secret. Generate with: `openssl rand -base64 48`.
JWT_SECRET=change-me-please-use-a-long-random-secret
# Cookie lifetime in seconds (7 days).
JWT_TTL=604800

# --- Observability (OpenTelemetry → Axiom) ---
# Pipeline works against stubbed config now; real creds come later.
AXIOM_URL=https://api.axiom.co
AXIOM_TOKEN=axiom-ingest-token
AXIOM_DATASET=baanthong-traces
